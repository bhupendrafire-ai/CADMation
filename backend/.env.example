# === LLM API Keys (populate before Step 5) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === CORS — allowed frontend origins ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Optional: BOM Excel/logs folder (default: repo/BOM_Outputs or EXE_dir/BOM_Outputs when frozen) ===
# CADMATION_BOM_OUTPUT_DIR=

# === LLM Provider: "openai" or "anthropic" ===
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
